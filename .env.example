# XSIAM HTTP Ingest
XSIAM_URL=https://<tenant>.xdr.us.paloaltonetworks.com/logs/v1/event
XSIAM_API_KEY=<your-api-key>
XSIAM_AUTH_ID=1
XSIAM_DATASET=xsiam_log_engine

# BrokerVM
BROKERVM_HOST=192.168.1.100
BROKERVM_SYSLOG_PORT=514
BROKERVM_SYSLOG_PROTO=udp
BROKERVM_WEC_PORT=5985
BROKERVM_WEC_USE_TLS=false

# TLS (optional, for syslog TLS or WEC HTTPS)
TLS_CA_CERT_PATH=
TLS_CLIENT_CERT_PATH=
TLS_CLIENT_KEY_PATH=

# Engine
ENGINE_API_PORT=8080
ENGINE_DEFAULT_EPS=10
ENGINE_LOG_LEVEL=INFO
# When set, every /api/* request must send it (X-Engine-Token header,
# or ?token= for SSE streams). Leave empty to disable authentication.
ENGINE_API_TOKEN=
