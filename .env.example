# ─── XSIAM HTTP Log Collector ──────────────────────────────────────────────
# URL format: https://api-<tenant-external-url>/logs/v1/event
XSIAM_URL=https://api-<tenant-external-url>/logs/v1/event
# API key from XSIAM Settings > API Keys (sent verbatim as the Authorization header)
XSIAM_API_KEY=<your-api-key>
# Default target dataset (per-source datasets are set in code)
XSIAM_DATASET=xsiam_log_engine

# ─── BrokerVM (Syslog + WEC) ───────────────────────────────────────────────
BROKERVM_HOST=192.168.1.100
BROKERVM_SYSLOG_PORT=514
BROKERVM_SYSLOG_PROTO=udp          # udp | tcp | tls
# Fallback WEC port used only when WEC_SUBSCRIPTION_URL is not set
BROKERVM_WEC_PORT=5986

# ─── WEC (Windows Event Forwarding) ────────────────────────────────────────
# Full subscription manager string copied from the BrokerVM. The engine parses
# the Server= component for the WEC host + port. Auth is via TLS client cert —
# upload the BrokerVM-issued .pfx in the GUI (Configuration > WEC Client Certificate).
# Example:
# WEC_SUBSCRIPTION_URL=Server=HTTPS://bvm.lab:5986/wsman/SubscriptionManager/WEC,Refresh=600,IssuerCA=37210BA1582B95CB0CB558C572B503C349692604
WEC_SUBSCRIPTION_URL=

# TLS client cert/key paths — populated automatically by the .pfx upload.
# Do not set these by hand.
TLS_CLIENT_CERT_PATH=
TLS_CLIENT_KEY_PATH=

# ─── Engine ────────────────────────────────────────────────────────────────
ENGINE_API_PORT=8080
ENGINE_DEFAULT_EPS=10
ENGINE_LOG_LEVEL=INFO
# When set, every /api/* request must present it (X-Engine-Token header, or
# ?token= for SSE streams). Leave empty to disable authentication.
ENGINE_API_TOKEN=
